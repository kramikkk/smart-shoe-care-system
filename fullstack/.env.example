# Database Configuration
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://username:password@localhost:5432/smart_shoe_care?schema=public"

# Better Auth Configuration
# Generate a random secret key for production (use: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-secret-key-here-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Trusted Origins for CORS (comma-separated list)
# Add all domains that should be allowed to access your API
# Example: "http://localhost:3000,http://192.168.1.12:3000,https://yourdomain.com"
TRUSTED_ORIGINS="http://localhost:3000"

# Gemini AI API Key (server-side only — do NOT prefix with NEXT_PUBLIC_)
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# PayMongo Payment Gateway Configuration
# Get your API keys from https://dashboard.paymongo.com/developers
# Use sk_test_... for testing, sk_live_... for production
PAYMONGO_SECRET_KEY="sk_live_your_paymongo_secret_key_here"

# PayMongo Webhook Secret (for webhook signature verification)
# Get this from your PayMongo dashboard webhook settings
PAYMONGO_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# WebSocket Authentication Token
# Used by web clients to authenticate WebSocket connections
# Generate a strong random token (use: openssl rand -hex 32)
WS_AUTH_TOKEN="your-ws-auth-token-here-change-in-production"

# Debug Logging (set to "true" to enable browser console logs)
# Leave unset or "false" in production
NEXT_PUBLIC_DEBUG="false"


# Contact Form (Resend)
RESEND_API_KEY="re_..."
CONTACT_EMAIL="your-email@gmail.com"
